{
  "name": "@ljcamargo/quirkvis-core",
  "version": "0.1.4",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --minify --keep-names --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts"
  },
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/lodash.merge": "^4.6.9"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "lodash.merge": "^4.6.2",
    "qasm-ts": "^2.1.4"
  }
}
